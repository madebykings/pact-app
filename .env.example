# =============================================================================
# Pact — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never NEXT_PUBLIC_

# --- App URLs ---
NEXT_PUBLIC_SITE_URL=https://pact.madebykings.com
NEXT_PUBLIC_BASE_URL=https://pact.madebykings.com  # used in invite links

# --- Cron protection ---
# Any random secret string. Pass as ?secret=... when calling cron endpoints.
CRON_SECRET=replace-with-a-long-random-string

# --- Superadmin ---
# Email address of the superadmin user. Must match their Supabase auth email exactly.
# The superadmin page is at /superadmin.
NEXT_PUBLIC_SUPERADMIN_EMAIL=you@example.com   # shown client-side for page-level redirect
SUPERADMIN_EMAIL=you@example.com               # server-side check in admin API routes

# =============================================================================
# WhatsApp reminders via Twilio
# =============================================================================

# Feature flag — set to "true" to enable WhatsApp UI and cron sending.
# When "true", the push notification UI is hidden and WhatsApp section is shown.
# When not "true" (default), all WhatsApp code is inactive and OneSignal UI remains.
NEXT_PUBLIC_WHATSAPP_ENABLED=false
WHATSAPP_ENABLED=false

# Twilio credentials (server-side only — no NEXT_PUBLIC_ prefix)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token

# The WhatsApp sender number in whatsapp:+E164 format.
# Sandbox:    whatsapp:+14155238886
# Production: whatsapp:+your-approved-number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
